{
  "name": "daggre",
  "version": "0.1.1",
  "description": "Convenience layer for dagre-d3",
  "main": "dist/index.js",
  "repository": "git@github.com:1kbgz/daggre.git",
  "author": "1kbgz <dev@1kbgz.com>",
  "license": "Apache-2.0",
  "type": "module",
  "module": "src/index.js",
  "browser": "dist/index.js",
  "unpkg": "dist/index.js",
  "jsdelivr": "dist/index.js",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build:esbuild": "esbuild src/index.js src/anywidget.js --bundle --format=esm --outdir=dist/",
    "build:python": "esbuild src/index.js src/anywidget.js --bundle --format=esm --outdir=../python/daggre/static/",
    "build:wasm": "node -e \"const fs=require('fs'),p=require.resolve('@1kbgz/transports/dist/pkg/transports_bg.wasm');['dist','../python/daggre/static'].forEach(d=>{fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p,d+'/transports_bg.wasm')})\"",
    "build": "npm-run-all -p build:*",
    "clean": "rimraf dist lib",
    "fix": "yarn lint --fix",
    "lint": "eslint --ext js src/ ../examples/*/*.js",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config .jestrc.js --forceExit --coverage",
    "watch:server": "http-server -p 3000 -o /examples",
    "watch:esbuild": "yarn build:esbuild --watch",
    "watch": "npm-run-all -p watch:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@1kbgz/transports": "^0.3.0",
    "dagre-d3-es": "^7.0.14"
  }
}
