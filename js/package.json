{
  "name": "daggre",
  "version": "0.1.1",
  "description": "dagre-d3 widgets",
  "repository": "git@github.com:1kbgz/daggre.git",
  "author": "the daggre authors <dev@1kbgz.com>",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "unpkg": "dist/cdn/index.js",
  "jsdelivr": "dist/cdn/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "index.d.ts"
  ],
  "types": "./dist/esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:esbuild": "esbuild src/index.js src/anywidget.js --bundle --format=esm --outdir=dist/",
    "build:python": "esbuild src/index.js src/anywidget.js --bundle --format=esm --outdir=../daggre/static/",
    "build:wasm": "node -e \"const fs=require('fs'),p=require.resolve('@1kbgz/transports/dist/pkg/transports_bg.wasm');['dist','../daggre/static'].forEach(d=>{fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p,d+'/transports_bg.wasm')})\"",
    "build": "npm-run-all -p build:*",
    "clean": "rm -rf dist playwright-report ../daggre/extension",
    "dev": "npm-run-all -p start watch",
    "lint": "prettier --check \"src/**/*.{js,ts,jsx,tsx,css}\" \"tests/**/*.{js,ts,jsx,tsx}\" \"*.mjs\" \"*.json\"",
    "fix": "prettier  --write \"src/**/*.{js,ts,jsx,tsx,css}\" \"tests/**/*.{js,ts,jsx,tsx}\" \"*.mjs\" \"*.json\"",
    "preinstall": "npx only-allow pnpm",
    "prepack": "npm run build",
    "start": "http-server -p 3000 -o examples/",
    "start:tests": "http-server -p 3000 ",
    "test": "TZ=UTC playwright test",
    "watch": "nodemon --watch src -e ts,css,html --exec \"pnpm build:debug\""
  },
  "dependencies": {
    "@1kbgz/transports": "^0.4.0",
    "dagre-d3-es": "^7.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "cpy": "^13.2.2",
    "esbuild": "^0.28.0",
    "http-server": "^14.1.1",
    "lightningcss": "^1.29.3",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
